#!/bin/sh
# postinst hook for factory-desktop deb package.
# Reloads systemd and enables the update manager --user service.
#
# IMPORTANT: Do NOT use dollar-brace shell syntax in this file.
# electron-builder's fpm target treats dollar-brace-alpha as a template
# macro and throws "Macro <name> is not defined" on unknown names.
# Use $var (no braces) instead — it is valid POSIX shell.

set -e

# Set SUID bit on chrome-sandbox so the app launches normally
# without --no-sandbox (VAL-RUNTIME-010). electron-builder strips
# the SUID bit during packaging; it must be restored at install time.
SANDBOX="/opt/Factory/chrome-sandbox"
if [ -f "$SANDBOX" ]; then
    chown root:root "$SANDBOX" 2>/dev/null || true
    chmod 4755 "$SANDBOX" 2>/dev/null || true
fi

# Install the update manager binary, service unit, and polkit policy
# from the staged app dir to system paths.
APP_DIR="/opt/Factory"
UPDATER_STAGED="$APP_DIR/.factory-linux/updater"
if [ -d "$UPDATER_STAGED" ]; then
    # Updater binary
    if [ -f "$UPDATER_STAGED/factory-update-manager" ]; then
        # Use atomic rename to avoid "Text file busy" when the updater
        # binary is still running (the daemon is a --user service that
        # may be active during the install). cp overwrites in-place and
        # fails with ETXTBSY; mv atomically replaces the inode, letting
        # the old process keep running with the old file mapped.
        cp "$UPDATER_STAGED/factory-update-manager" /usr/bin/factory-update-manager.new
        chown root:root /usr/bin/factory-update-manager.new
        chmod 755 /usr/bin/factory-update-manager.new
        mv -f /usr/bin/factory-update-manager.new /usr/bin/factory-update-manager
    fi
    # Systemd user service unit
    if [ -f "$UPDATER_STAGED/factory-update-manager.service" ]; then
        mkdir -p /usr/lib/systemd/user
        cp "$UPDATER_STAGED/factory-update-manager.service" /usr/lib/systemd/user/factory-update-manager.service
        chmod 644 /usr/lib/systemd/user/factory-update-manager.service
    fi
    # Polkit policy
    if [ -f "$UPDATER_STAGED/org.factory.desktop.update-manager.policy" ]; then
        mkdir -p /usr/share/polkit-1/actions
        cp "$UPDATER_STAGED/org.factory.desktop.update-manager.policy" /usr/share/polkit-1/actions/
        chmod 644 /usr/share/polkit-1/actions/org.factory.desktop.update-manager.policy
    fi
fi

# Install the builder checkout for local rebuilds
BUILDER_STAGED="$APP_DIR/.factory-linux/update-builder"
if [ -d "$BUILDER_STAGED" ]; then
    mkdir -p /opt/factory-desktop
    cp -r "$BUILDER_STAGED" /opt/factory-desktop/update-builder
fi
# Create the ~/.factory/automations directory for each logged-in user.
# The app checks for this directory on startup and logs an ENOENT warning
# if it doesn't exist. Creating it here suppresses the warning.
if command -v systemctl >/dev/null 2>&1; then
    for user_dir in /run/user/*/; do
        [ -d "$user_dir" ] || continue
        uid=$(basename "$user_dir")
        home_dir=$(getent passwd "$uid" | cut -d: -f6)
        [ -n "$home_dir" ] && [ -d "$home_dir" ] || continue
        mkdir -p "$home_dir/.factory/automations" 2>/dev/null || true
        chown "$uid" "$home_dir/.factory/automations" 2>/dev/null || true
    done
fi

# Refresh icon cache so GNOME/taskbar picks up the installed hicolor icons.
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -f /usr/share/icons/hicolor/ >/dev/null 2>&1 || true
fi

UNIT="factory-update-manager.service"

# Reload the system daemon so the user unit is visible.
if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
fi

# Reload user manager instances for logged-in users, and best-effort
# enable + start the update-manager service for each.
if command -v systemctl >/dev/null 2>&1; then
    for user_dir in /run/user/*/; do
        [ -d "$user_dir" ] || continue
        uid=$(basename "$user_dir")
        systemctl --user --machine="$uid@.host" daemon-reload >/dev/null 2>&1 || true
        systemctl --user --machine="$uid@.host" enable "$UNIT" >/dev/null 2>&1 || true
        systemctl --user --machine="$uid@.host" start "$UNIT" >/dev/null 2>&1 || true
    done
fi

exit 0
